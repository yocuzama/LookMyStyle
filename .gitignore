# Archivos de entorno y configuraciones locales
.env
.env.*
!.env.example

# Entornos virtuales
.venv/
venv/
env/

# Archivos de dependencias o cachés de Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pkl
*.db
*.sqlite3

# Configuraciones del IDE
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Archivos temporales del sistema
.DS_Store
Thumbs.db

# Archivos de build o distribuciones
build/
dist/
*.egg-info/

# Logs
*.log

# Archivos de prueba o cobertura
.coverage
htmlcov/
.pytest_cache/

# Archivos generados automáticamente por herramientas
.mypy_cache/
__pypackages__/
.pyre/

# Configuración de OS
*.swp
*.bak
*.tmp
*.orig
